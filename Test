import sys

def greet_user(name):
    """Simple function to demonstrate string formatting."""
    return f"Hello, {name}! Welcome to Python in VS Code."

def math_demo(numbers):
    """Calculates the square of numbers to show a list comprehension."""
    return [n**2 for n in numbers]

def main():
    print("--- VS Code Python Test ---")
    
    # 1. Test basic output and user input
    user_name = input("Enter your name: ") or "Guest"
    print(greet_user(user_name))
    
    # 2. Test logic and loops
    nums = [1, 2, 3, 4, 5]
    squares = math_demo(nums)
    print(f"The squares of {nums} are {squares}")
    
    # 3. Test environment info
    print(f"Python Version: {sys.version.split()[0]}")
    print("--- Test Complete ---")

if __name__ == "__main__":
    main()